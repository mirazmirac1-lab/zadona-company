# Local development only.
# On Railway, DATABASE_URL is provided automatically once you attach
# a PostgreSQL plugin to this project — you do not need to set it manually there.
DATABASE_URL=postgresql://user:password@localhost:5432/zadona
PORT=3000

# Optional Twilio SMS settings for password reset delivery
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_PHONE=+1234567890
